{
  "description": "Scans prompts and tool outputs for leaked credentials using TruffleHog, blocking them before they reach Anthropic",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/cc-guard",
            "args": [],
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/cc-guard",
            "args": [],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
